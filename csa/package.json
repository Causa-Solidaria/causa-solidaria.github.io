{
  "name": "csa",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:dev && npm run prisma:generate:dev  && next dev",
    "build": "npm run prisma:generate:prod && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "vercel-build": "npm run build",
    "prisma:generate:dev": "prisma generate --schema=./prisma/schema.dev.prisma",
    "prisma:generate:prod": "prisma generate --schema=./prisma/schema.prod.prisma",
    "build:standalone": "BUILD_TARGET=standalone next build",
    "start:standalone": "next start",
    "db:dev": "prisma migrate dev --schema=./prisma/schema.dev.prisma --create-only --name dev",
    "db:prod": "prisma migrate deploy --schema=./prisma/schema.prod.prisma --name prod",
    "db:deploy": "npm run db:prod"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.19.0",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@hookform/resolvers": "^5.0.1",
    "@prisma/client": "^6.14.0",
    "bcryptjs": "^3.0.2",
    "framer-motion": "^12.23.11",
    "fs": "^0.0.1-security",
    "jsonwebtoken": "^9.0.2",
    "lz-string": "^1.5.0",
    "multer": "^2.0.2",
    "next": "^16.0.0",
    "next-connect": "^1.0.0-next.4",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.56.4",
    "react-icons": "^5.5.0",
    "react-shadow": "^20.6.0",
    "sharp": "^0.34.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "babel-plugin-styled-components": "^2.1.4",
    "baseline-browser-mapping": "^2.8.32",
    "eslint": "^9",
    "eslint-config-next": "^15.3.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8",
    "prisma": "^6.14.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
