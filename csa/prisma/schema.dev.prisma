datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TipoVoto {
  UP
  DOWN
}

model User {
  id               Int      @id @default(autoincrement())
  public_id        String   @default(uuid())
  name             String
  username         String   @unique
  age              Int
  email            String   @unique
  senha            String
  bio              String?
  foto             String?
  numero           String?
  localizacao      String?
  areasDeInteresse String?
  genero           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campanhas Campanha[]
  ong       Ong[]

  // Relacionamentos Fórum
  topicos         ForumTopico[]
  comentarios     ForumComentario[]
  votosTopico     ForumVoteTopico[]
  votosComentario ForumVoteComentario[]
}

model TokenRedefinicaoSenha {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime
}

model Campanha {
  id         String   @id @default(uuid())
  titulo     String
  descricao  String?
  nivelAjuda String
  cep        String
  cidade     String
  estado     String
  bairro     String
  rua        String
  numero     String
  metaTipo   String   @default("dinheiro")
  meta       Float    @default(0)
  metaItem   String?
  foto       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  endDate    DateTime

  usuarioId Int
  usuario   User @relation(fields: [usuarioId], references: [id])
}

model Ong {
  id          Int      @id @default(autoincrement())
  nome        String
  cnpj        String   @unique
  areaAtuacao String
  descricao   String
  cep         String
  cidade      String?
  uf          String?
  rua         String?
  numero      String?
  bairro      String?
  contato     String
  siteOuRede  String
  logoUrl     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  usuarioId Int
  usuario   User @relation(fields: [usuarioId], references: [id])
}

model ForumTopico {
  id               Int     @id @default(autoincrement())
  uuid             String  @unique @default(uuid())
  titulo           String
  descricao        String
  slug             String  @unique
  isHot            Boolean @default(false)
  karma            Int     @default(0)
  totalComentarios Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarioId Int
  usuario   User @relation(fields: [usuarioId], references: [id])

  comentarios ForumComentario[]
  votos       ForumVoteTopico[]
  tags        ForumTagOnTopico[]

  @@index([titulo])
  @@index([createdAt])
}

model ForumComentario {
  id       Int    @id @default(autoincrement())
  uuid     String @unique @default(uuid())
  conteudo String
  karma    Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarioId Int
  usuario   User @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  topicoId Int
  topico   ForumTopico @relation(fields: [topicoId], references: [id], onDelete: Cascade)

  votos ForumVoteComentario[]

  @@index([topicoId])
}

model ForumVoteTopico {
  id        Int      @id @default(autoincrement())
  tipo      TipoVoto
  createdAt DateTime @default(now())

  topicoId Int
  topico   ForumTopico @relation(fields: [topicoId], references: [id], onDelete: Cascade)

  usuarioId Int
  usuario   User @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([topicoId, usuarioId])
}

model ForumVoteComentario {
  id        Int      @id @default(autoincrement())
  tipo      TipoVoto
  createdAt DateTime @default(now())

  comentarioId Int
  comentario   ForumComentario @relation(fields: [comentarioId], references: [id], onDelete: Cascade)

  usuarioId Int
  usuario   User @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([comentarioId, usuarioId])
}

model ForumTagOnTopico {
  id  Int    @id @default(autoincrement())
  tag String

  topicoId Int
  topico   ForumTopico @relation(fields: [topicoId], references: [id], onDelete: Cascade)

  @@unique([topicoId, tag])
}
